@model Telecom.UI.Models.CreateTicketViewModel

@{
    ViewData["Title"] = "Create Ticket";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="glass-card">
                <h3 class="neon-text mb-4"><i class="bi bi-file-earmark-plus"></i> Open New Fault Ticket</h3>
                <hr class="border-secondary mb-4"/>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row mb-3">
                        <div class="col-md-6 form-group">
                            <label asp-for="CustomerNo" class="control-label text-light">Customer Number</label>
                            <input asp-for="CustomerNo" class="form-control glass-input" placeholder="e.g. CUST-10001" />
                            <span asp-validation-for="CustomerNo" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 form-group">
                            <label asp-for="Priority" class="control-label text-light">Priority Level</label>
                            <select asp-for="Priority" class="form-select glass-input">
                                <option value="1">Low</option>
                                <option value="2" selected>Medium</option>
                                <option value="3">High</option>
                                <option value="4">Critical</option>
                            </select>
                            <span asp-validation-for="Priority" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Title" class="control-label text-light">Fault Title</label>
                        <input asp-for="Title" class="form-control glass-input" placeholder="Brief description of the issue" />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-4">
                        <label asp-for="Description" class="control-label text-light">Detailed Description</label>
                        <textarea asp-for="Description" class="form-control glass-input" rows="4" placeholder="Provide detailed information..."></textarea>
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>

                    <div class="form-group d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-neon px-5">Submit Ticket</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
