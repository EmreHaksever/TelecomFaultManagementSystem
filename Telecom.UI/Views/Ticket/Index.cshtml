@model IEnumerable<Telecom.UI.Models.TicketViewModel>
@{
    ViewData["Title"] = "Active Tickets";
    // Rolü cookie'den okuyoruz çünkü UI tarafı JWT'yi çözmüyor
    var userRole = Context.Request.Cookies["UserRole"] ?? "";
    var isAgent  = userRole == "Agent" || userRole == "Admin";
    var isTech   = userRole == "Technician";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="neon-text">Active Fault Tickets</h2>
        @* 🟢 FIX: "New Ticket" sadece Agent/Admin için görünür *@
        @if (isAgent)
        {
            <a asp-action="Create" class="btn btn-neon-outline"><i class="bi bi-plus-lg"></i> New Ticket</a>
        }
    </div>

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table glass-table">
                <thead>
                    <tr>
                        <th>Customer No</th>
                        <th>Title</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>SLA Due</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge glass-badge">@item.CustomerNo</span></td>
                            <td class="text-light fw-bold">@item.Title</td>
                            <td>
                                @* 🟢 FIX: Her öncelik ayrı badge *@
                                @if(item.Priority == 4)      { <span class="badge bg-danger">Critical</span> }
                                else if(item.Priority == 3)  { <span class="badge bg-warning text-dark">High</span> }
                                else if(item.Priority == 2)  { <span class="badge bg-info text-dark">Medium</span> }
                                else                         { <span class="badge bg-secondary">Low</span> }
                            </td>
                            <td>
                                @if(item.Status == 1) { <span class="badge bg-success">Open</span> }
                                else if(item.Status == 2) { <span class="badge bg-warning text-dark">In Progress</span> }
                                else if(item.Status == 3) { <span class="badge bg-primary">Resolved</span> }
                                else { <span class="badge bg-secondary">Closed</span> }
                            </td>
                            <td class="text-muted">@(item.SLADueDate?.ToString("g") ?? "-")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-1">Details</a>
                                
                                @* 🟡 FIX: Koşullu butonlar - duruma göre göster *@
                                @if(item.Status == 1 && isAgent) // Open → Agent atar
                                {
                                    <a asp-action="Assign" asp-route-id="@item.Id" class="btn btn-sm btn-primary me-1">
                                        <i class="bi bi-person-plus"></i> Assign
                                    </a>
                                }
                                
                                @if(item.Status == 2) // InProgress → Teknisyen çözer
                                {
                                    <a asp-action="Resolve" asp-route-id="@item.Id" class="btn btn-sm btn-success me-1">
                                        <i class="bi bi-check-lg"></i> Resolve
                                    </a>
                                }

                                @* Silme butonu sadece Agent/Admin'e görünür *@
                                @if (isAgent)
                                {
                                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline"
                                          onsubmit="return confirm('Are you sure you want to delete this ticket? This cannot be undone.');">
                                        <button type="submit" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    @if(!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">No tickets found in the system.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
