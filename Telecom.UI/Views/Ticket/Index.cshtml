@model IEnumerable<Telecom.UI.Models.TicketViewModel>

@{
    ViewData["Title"] = "Active Tickets";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="neon-text">Active Fault Tickets</h2>
        <a asp-action="Create" class="btn btn-neon-outline"><i class="bi bi-plus-lg"></i> New Ticket</a>
    </div>

    <div class="glass-card p-4">
        <div class="table-responsive">
            <table class="table glass-table">
                <thead>
                    <tr>
                        <th>Customer No</th>
                        <th>Title</th>
                        <th>Priority</th>
                        <th>Status</th>
                        <th>SLA Due</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="badge glass-badge">@item.CustomerNo</span></td>
                            <td class="text-light fw-bold">@item.Title</td>
                            <td>
                                @if(item.Priority == 4) { <span class="badge bg-danger">Critical</span> }
                                else if(item.Priority == 3) { <span class="badge bg-warning text-dark">High</span> }
                                else { <span class="badge bg-info text-dark">Medium/Low</span> }
                            </td>
                            <td>
                                @if(item.Status == 1) { <span class="badge bg-success">Open</span> }
                                else if(item.Status == 2) { <span class="badge bg-warning text-dark">In Progress</span> }
                                else if(item.Status == 3) { <span class="badge bg-primary">Resolved</span> }
                                else { <span class="badge bg-secondary">Closed</span> }
                            </td>
                            <td class="text-muted">@(item.SLADueDate?.ToString("g") ?? "-")</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info me-2">Details</a>
                                <a asp-action="Assign" asp-route-id="@item.Id" class="btn btn-sm btn-primary">
                                    <i class="bi bi-person-plus me-1"></i>Assign
                                </a>
                            </td>
                        </tr>
                    }
                    @if(!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">No tickets found in the system.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
