@{
    ViewData["Title"] = "Resolve Ticket";
}

<div class="container mt-5">
    <div class="glass-card p-5 animate-fade-in mx-auto" style="max-width: 700px;">
        <h2 class="neon-text text-center mb-4"><i class="bi bi-check2-all me-2"></i>Resolve Ticket</h2>
        <p class="text-light opacity-75 text-center mb-4">Please provide details about how you fixed this issue.</p>
        <hr class="glass-hr">

        <form asp-action="Resolve" method="post">
            <input type="hidden" name="ticketId" value="@ViewBag.TicketId" />
            
            <div class="mb-4">
                <label class="form-label text-light fw-bold">Resolution Details</label>
                <textarea name="resolutionDetail" class="form-control glass-input" rows="6" 
                          placeholder="Explain the solution (e.g., 'Replaced faulty router', 'Reset port on DSLAM')..." required></textarea>
                <div class="form-text text-light opacity-50 small mt-2">
                    This information will be visible to agents and the customer support team.
                </div>
            </div>

            <div class="d-grid gap-2">
                <button type="submit" class="btn btn-success btn-lg py-3">
                    <i class="bi bi-send-check me-2"></i>Submit Resolution
                </button>
                <a asp-action="Index" class="btn btn-outline-light py-2 opacity-75">
                    Go Back
                </a>
            </div>
            
            <div asp-validation-summary="ModelOnly" class="text-danger mt-3 small text-center"></div>
        </form>
    </div>
</div>
