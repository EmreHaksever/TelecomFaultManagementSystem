@model Telecom.UI.Models.TicketViewModel
@{
    ViewData["Title"] = "Ticket Details";
}

<div class="container mt-5">
    <div class="glass-card p-5 animate-fade-in">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="neon-text">Ticket Details</h2>
            <div>
                @if(Model.Status == 1) { <span class="badge bg-success p-2 fs-6">Open</span> }
                else if(Model.Status == 2) { <span class="badge bg-warning text-dark p-2 fs-6">In Progress</span> }
                else if(Model.Status == 3) { <span class="badge bg-primary p-2 fs-6">Resolved</span> }
                else { <span class="badge bg-secondary p-2 fs-6">Closed</span> }
            </div>
        </div>
        
        <hr class="glass-hr">

        <div class="row mt-4">
            <div class="col-md-8">
                <h3 class="text-light">@Model.Title</h3>
                <p class="text-light opacity-75 mt-3" style="white-space: pre-line;">
                    @Model.Description
                </p>
            </div>
            <div class="col-md-4 border-start border-secondary border-opacity-25 ps-4">
                <div class="mb-4">
                    <label class="text-muted small d-block">Customer No</label>
                    <span class="text-light fw-bold">@Model.CustomerNo</span>
                </div>
                <div class="mb-4">
                    <label class="text-muted small d-block">Priority</label>
                    @if(Model.Priority == 4) { <span class="badge bg-danger">Critical</span> }
                    else if(Model.Priority == 3) { <span class="badge bg-warning text-dark">High</span> }
                    else { <span class="badge bg-info text-dark">Medium/Low</span> }
                </div>
                <div class="mb-4">
                    <label class="text-muted small d-block">SLA Due Date</label>
                    <span class="text-light">@(Model.SLADueDate?.ToString("f") ?? "Not Set")</span>
                </div>
                <div class="mb-4">
                    <label class="text-muted small d-block">Created At</label>
                    <span class="text-muted small">@Model.CreatedAt.ToString("f")</span>
                </div>
            </div>
        </div>

        <div class="mt-5 d-flex gap-3">
            <a asp-action="Assign" asp-route-id="@Model.Id" class="btn glass-button-primary px-4">
                <i class="bi bi-person-plus me-2"></i>Assign Technician
            </a>
            <a asp-action="Index" class="btn btn-outline-light px-4">
                Back to List
            </a>
        </div>
    </div>
</div>
